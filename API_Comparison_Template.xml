<?xml version='1.0' encoding='UTF-8'?>
<testSuite>
  <settings>
    <suiteName>User API Regression Tests</suiteName>
    <description>Test suite for User Management APIs during v2.0 migration</description>
    <version>1.0</version>
    <createdBy>john.doe@company.com</createdBy>
    <createdDate>2025-01-15</createdDate>
    <lastUpdatedBy>jane.smith@company.com</lastUpdatedBy>
    <lastUpdatedDate>2025-01-20</lastUpdatedDate>
    <executionConfig>
      <mode>parallel</mode>
      <timeout>30</timeout>
      <parallelLimit>10</parallelLimit>
      <delayBetweenRequests>100</delayBetweenRequests>
      <retries>2</retries>
    </executionConfig>
    <comparisonConfig>
      <caseSensitive>true</caseSensitive>
      <ignoreArrayOrder>false</ignoreArrayOrder>
      <numericTolerance>0.001</numericTolerance>
      <ignoreFields>timestamp,requestId,executionTime</ignoreFields>
    </comparisonConfig>
  </settings>
  <environment>
    <source url="https://api-legacy.company.com" authProfile="Legacy-SAML"/>
    <target url="https://api-new.company.com" authProfile="Modern-OAuth2"/>
    <sourceAuthProfile>Legacy-SAML</sourceAuthProfile>
    <targetAuthProfile>Modern-OAuth2</targetAuthProfile>
    <sourceUrl>https://api-legacy.company.com</sourceUrl>
    <targetUrl>https://api-new.company.com</targetUrl>
    <defaultHeaders>
      <defaultHeader name="Content-Type" source="application/json" target="application/json"/>
      <defaultHeader name="Accept" source="application/json" target="application/json"/>
      <defaultHeader name="X-API-Version" source="1.0" target="2.0"/>
      <defaultHeader name="X-Client-Name" source="Legacy-Client" target="Modern-Client"/>
      <defaultHeader name="X-Environment" source="legacy" target="production"/>
    </defaultHeaders>
  </environment>
  <authProfiles>
    <authProfile name="Legacy-SAML" description="SAML authentication for legacy environment" tokenUrl="https://sso.company.com/saml/token" username="api-user@company.com" password="********" entityId="legacy-api-entity" type="SAML"/>
    <authProfile name="Modern-OAuth2" description="OAuth2 for modern environment" tokenUrl="https://auth.company.com/oauth/token" clientId="api-client-v2" clientSecret="********" scope="api:read api:write" type="CLIENT_CREDENTIALS"/>
    <authProfile name="Admin-Basic" description="Basic auth for admin operations" username="admin" password="admin123" type="BASIC"/>
    <authProfile name="Public-Bearer" description="Static bearer token for public API" token="public-api-token-12345" type="BEARER"/>
    <authProfile name="Payment-OAuth2" description="OAuth2 for payment service" tokenUrl="https://payment-auth.company.com/oauth/token" clientId="payment-client" clientSecret="payment-secret" scope="payment:process" additionalConfig="{&quot;audience&quot;: &quot;payment-api&quot;}" type="CLIENT_CREDENTIALS"/>
    <authProfile name="No-Auth" description="No authentication required" type="NONE"/>
  </authProfiles>
  <testGroups>
    <testGroup name="User APIs" owner="john.doe@company.com">
      <description>User management API tests for v2.0 migration</description>
      <testCase id="TC001" name="Get User Profile" enabled="true" method="GET" endpoint="/api/users/12345">
        <description>Retrieve user profile by user ID</description>
        <jsonBody/>
        <headers/>
        <author>john.doe@company.com</author>
        <comparisonConfig/>
        <result>
          <status>passed</status>
          <differences></differences>
          <sourceStatus>200</sourceStatus>
          <targetStatus>200</targetStatus>
          <sourceResponse>{"id": 12345, "name": "John Doe", "email": "john@example.com"}</sourceResponse>
          <targetResponse>{"id": 12345, "name": "John Doe", "email": "john@example.com"}</targetResponse>
          <executedAt>2025-01-15 10:30:15</executedAt>
        </result>
        <queryParams>
          <queryParam key="include" value="profile"/>
          <queryParam key="include" value="preferences"/>
        </queryParams>
        <formParams/>
      </testCase>
      <testCase id="TC002" name="Create New User" enabled="true" method="POST" endpoint="/api/users">
        <description>Create a new user account with validation</description>
        <jsonBody>{"name": "John Doe", "email": "john.doe@example.com", "role": "user"}</jsonBody>
        <headers/>
        <author>jane.smith@company.com</author>
        <comparisonConfig/>
        <result>
          <status>failed</status>
          <differences>Response field "created_at" format differs: ISO string vs timestamp</differences>
          <sourceStatus>201</sourceStatus>
          <targetStatus>201</targetStatus>
          <sourceResponse>{"id": 67890, "created_at": "2025-01-15T10:30:15Z"}</sourceResponse>
          <targetResponse>{"id": 67890, "created_at": 1737024615}</targetResponse>
          <executedAt>2025-01-15 10:30:17</executedAt>
        </result>
        <queryParams/>
        <formParams/>
      </testCase>
      <testCase id="TC003" name="Update User Email" enabled="true" method="PUT" endpoint="/api/users/12345/email">
        <description>Update user email address</description>
        <jsonBody>{"email": "newemail@example.com"}</jsonBody>
        <headers/>
        <author>mike.wilson@company.com</author>
        <comparisonConfig/>
        <result>
          <status>passed</status>
          <differences></differences>
          <sourceStatus>200</sourceStatus>
          <targetStatus>200</targetStatus>
          <sourceResponse>{"id": 12345, "email": "newemail@example.com"}</sourceResponse>
          <targetResponse>{"id": 12345, "email": "newemail@example.com"}</targetResponse>
          <executedAt>2025-01-15 10:30:19</executedAt>
        </result>
        <queryParams/>
        <formParams/>
      </testCase>
      <testCase id="TC004" name="Delete User Account" enabled="true" method="DELETE" endpoint="/api/users/12345">
        <description>Soft delete user account and associated data</description>
        <jsonBody/>
        <headers/>
        <author>sarah.jones@company.com</author>
        <comparisonConfig/>
        <result>
          <status>passed</status>
          <differences></differences>
          <sourceStatus>204</sourceStatus>
          <targetStatus>204</targetStatus>
          <sourceResponse></sourceResponse>
          <targetResponse></targetResponse>
          <executedAt>2025-01-15 10:30:21</executedAt>
        </result>
        <queryParams>
          <queryParam key="reason" value="user_request"/>
        </queryParams>
        <formParams/>
      </testCase>
      <testCase id="TC005" name="List Users with Pagination" enabled="true" method="GET" endpoint="/api/users">
        <description>Get paginated user list with filtering</description>
        <jsonBody/>
        <headers/>
        <author>david.brown@company.com</author>
        <comparisonConfig/>
        <result>
          <status>failed</status>
          <differences>Pagination key differs: legacy "total_count" vs new "total"</differences>
          <sourceStatus>200</sourceStatus>
          <targetStatus>200</targetStatus>
          <sourceResponse>{"users": [...], "pagination": {"total_count": 150}}</sourceResponse>
          <targetResponse>{"users": [...], "pagination": {"total": 150}}</targetResponse>
          <executedAt>2025-01-15 10:30:23</executedAt>
        </result>
        <queryParams>
          <queryParam key="page" value="1"/>
          <queryParam key="limit" value="10"/>
          <queryParam key="status" value="active"/>
        </queryParams>
        <formParams/>
      </testCase>
    </testGroup>
